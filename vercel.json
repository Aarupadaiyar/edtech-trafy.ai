{
  "cleanUrls": true,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/cohort", "destination": "/cohort/index.html" },
    { "source": "/cohort/apply", "destination": "/cohort/apply.html" },
    { "source": "/cohort/marketers", "destination": "/cohort/marketers/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
